# 이 파일을 복사해 .env 로 만들고 값을 채우세요:  cp .env.example .env
# .env 는 .gitignore 에 있어 커밋되지 않습니다. 키를 코드/채팅에 붙여넣지 마세요.

# ── 카피 생성 (필수: 실제 콘텐츠) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6        # (선택) 모델 override. 기본 sonnet(저렴)

# ── 이미지 렌더 (선택) ────────────────────────────────────────
# IMAGE_RENDERER=puppeteer              # 진짜 PNG (npm i puppeteer 필요). 기본 SVG

# ── 이미지 공개 호스팅 (IG 게시에 필요) ───────────────────────
# IMAGE_UPLOAD_BASE=https://<버킷-업로드-엔드포인트>
# IMAGE_PUBLIC_BASE=https://<버킷-공개-URL>
# IMAGE_UPLOAD_TOKEN=<R2/S3 토큰>

# ── 텔레그램 승인 알림 (선택) ─────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TELEGRAM_CHAT_ID=987654321

# ── 인스타그램/스레드 실게시 (선택) ───────────────────────────
# IG_USER_ID=
# IG_TOKEN=
# THREADS_USER_ID=
# THREADS_TOKEN=
